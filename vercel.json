{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "uv pip install -e .",
  "installCommand": "pip install -e .",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ],
  "functions": {
    "api/index.py": {
      "runtime": "python3.11",
      "excludeFiles": "{tests/**,__tests__/**,**/*.test.py,**/test_*.py,docs/**,.git/**,.venv/**,venv/**,.pytest_cache/**,.mypy_cache/**,**/__pycache__/**,**/*.pyc}"
    }
  }
}
